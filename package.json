{
  "name": "pulse-spotify-intelligence",
  "version": "1.0.0",
  "description": "Pulse — Spotify AI Feedback Intelligence System",
  "type": "module",
  "main": "api/server.js",
  "scripts": {
    "dev": "node api/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "seed": "node scripts/seed.js",
    "sync": "node scripts/run-pipeline.js",
    "scheduler": "node scheduler.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@xenova/transformers": "^2.17.2",
    "app-store-scraper": "*",
    "cheerio": "^1.0.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "franc": "^6.2.0",
    "google-play-scraper": "*",
    "node-cron": "^3.0.3",
    "snoowrap": "^1.23.0",
    "uuid": "^11.0.3"
  }
}
