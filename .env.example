# ============================================
# Pulse — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys.
# All keys are OPTIONAL — the app works with seed data out of the box.

# Google AI (Gemini) — free at https://aistudio.google.com
GOOGLE_AI_API_KEY=

# Reddit API — free at https://reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PulseBot/1.0

# Twitter API v2 — free at https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Slack webhook — free in any Slack workspace
SLACK_WEBHOOK_URL=

# HuggingFace (optional embedding fallback) — free at https://huggingface.co
HUGGINGFACE_API_KEY=

# ChromaDB (optional, falls back to in-memory vectors)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Server
PORT=3001
